PORT=4000
FRONTEND_URL=https://your-frontend-demo.vercel.app
PUBLIC_API_URL=https://your-backend-demo.up.railway.app
VITE_API_URL=https://your-backend-demo.up.railway.app/api

POSTGRES_DB=perchi
POSTGRES_USER=perchi
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5433
DATABASE_URL=postgresql://user:password@host:5432/perchi?schema=public

JWT_SECRET=change-me-to-a-long-random-secret
MONTHLY_FEE_CLP=6990

# Images
# local keeps files in backend/uploads for development.
# cloudinary uploads images outside the app server for scalable demos.
IMAGE_STORAGE_PROVIDER=local
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_UPLOAD_PRESET=
CLOUDINARY_FOLDER=perchi
